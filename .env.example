# Copy this file to backend/.env and fill in your values
# DO NOT put real credentials in this file

# ─── Claude AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./faithforge.db

# ─── Microsoft Graph API (recommended for Microsoft 365 / Outlook) ───────────
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_EMAIL_ADDRESS=
MS_AUTH_MODE=client_credentials

# ─── IMAP fallback (Gmail or if not using Graph API) ─────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=you@yourorg.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX
IMAP_USE_SSL=True
IMAP_SCAN_DAYS=30

# ─── SMTP fallback ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@yourorg.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True
SMTP_FROM_EMAIL=you@yourorg.com
SMTP_FROM_NAME=FaithForge AI

# ─── Notifications ────────────────────────────────────────────────────────────
NOTIFICATION_EMAIL=you@yourorg.com

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=False
